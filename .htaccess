# Configura횄짠횄짙o para Node.js na HostGator
DirectoryIndex disabled
RewriteEngine On

# Evita que o Apache tente listar arquivos e d챗 erro 403
Options -Indexes

# Encaminha todas as requisi횄짠횄쨉es para o seu app.js (atrav챕s do Passenger)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ app.js/$1 [QSA,L]
